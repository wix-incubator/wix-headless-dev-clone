---
import XRayToggle from "./xray/Toggle.tsx";
import WixLogo from "../assets/wix.svg";
---

<header class="topbar">
  <a class="wordmark" href="/" aria-label="wix-headless.dev — a Wix project" data-xray="page-shell">
    <WixLogo class="wordmark__logo" aria-hidden="true" />
    <span class="wordmark__divider" aria-hidden="true">/</span>
    <span class="wordmark__name">headless</span><span class="wordmark__tld">.dev</span>
  </a>
  <nav class="topnav">
    <a href="/skill.md" data-xray="skill-route">
      Skill
      <svg class="topnav__icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M8 2v9M4.5 7.5L8 11l3.5-3.5" />
        <path d="M2.5 13.5h11" />
      </svg>
    </a>
    <a href="https://dev.wix.com/docs/go-headless" target="_blank" rel="noreferrer">
      Docs
      <svg class="topnav__icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 3H3a1 1 0 0 0-1 1v9a1 1 0 0 0 1 1h9a1 1 0 0 0 1-1v-3" />
        <path d="M9 2h5v5" />
        <path d="M14 2L7.5 8.5" />
      </svg>
    </a>
    <XRayToggle client:load />
  </nav>
</header>
