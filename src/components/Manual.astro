---
import CliQuickstart from "./CliQuickstart.tsx";
---

<section class="bento__manual block" aria-labelledby="manual-title">
  <header class="manual__header">
    <span class="kicker">or, manually</span>
    <h2 id="manual-title" class="manual__title">Run it yourself.</h2>
    <p class="manual__lede">
      Not using a coding agent (yet)? The Wix CLI scaffolds the same headless project from your terminal &mdash; one command, complete control.
    </p>
  </header>
  <CliQuickstart client:load />
</section>
