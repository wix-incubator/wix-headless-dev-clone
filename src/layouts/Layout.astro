---
import "../styles/xray.css";
import XRayLayer from "../components/xray/Layer.tsx";

const SITE_URL = "https://www.wix-headless.dev";
const {
	title = "Build a Real Business with AI | Wix Headless",
	description = "Headless commerce, bookings, CMS, identity — agent-wired, prompt-deep. Drop one prompt into any coding agent and ship a business, not a demo.",
	ogTitle = "Build anything. Wix runs the business behind it.",
	ogDescription = "Headless commerce, bookings, CMS, identity — agent-wired, prompt-deep.",
	image = "/og-image.png",
	imageAlt = "Wix Headless — Build anything. Wix runs the business behind it.",
	canonical,
} = Astro.props;
const absoluteImage = image.startsWith("http") ? image : SITE_URL + image;
const ogUrl = canonical ?? SITE_URL + "/";
---
<!doctype html>
<html lang="en">
	<head>
		<slot name="seo-tags" />
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" sizes="192x192" href="/icon.png" />
		<link rel="apple-touch-icon" href="/icon.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="author" content="Wix.com, Inc." />
		{canonical && <link rel="canonical" href={canonical} />}
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={ogTitle} />
		<meta property="og:description" content={ogDescription} />
		<meta property="og:url" content={ogUrl} />
		<meta property="og:image" content={absoluteImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={imageAlt} />
		<meta name="twitter:site" content="@Wix" />
		<meta name="twitter:title" content={ogTitle} />
		<meta name="twitter:description" content={ogDescription} />
		<meta name="twitter:image" content={absoluteImage} />
		<meta name="twitter:image:alt" content={imageAlt} />
		<meta name="theme-color" content="#0a0a0a" />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebSite",
			name: "Wix Headless",
			url: SITE_URL + "/",
			publisher: {
				"@type": "Organization",
				name: "Wix",
				url: "https://www.wix.com/"
			}
		})} />
		<link rel="preconnect" href="https://rsms.me/" />
		<link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
		<!--
			Wix's injected cookie banner ([data-hook="ccsu-banner-root"]) ships a light
			"wix.com" look: white bar, Madefor brand font, black-outlined pill buttons.
			On this dark site that clashed (and it sets no text color of its own, so it
			inherited our light --fg onto a white bar = unreadable). Re-skin it onto the
			site's design tokens: dark card surface, Inter body / mono buttons, accent
			(primary = Accept) and outlined (Decline) matching the site's own buttons.

			!important is required: the consent bundle injects its stylesheet AFTER ours,
			so equal-specificity rules would lose on source order. Target the stable
			data-hooks, not the hashed classes (.aspXfg etc.) the bundle regenerates.
		-->
		<style is:global>
			[data-hook="ccsu-banner-root"] {
				background: var(--bg-card) !important;
				color: var(--fg) !important;
				border-top: 1px solid var(--border-strong);
				box-shadow: 0 -10px 40px -16px rgba(0, 0, 0, 0.7) !important;
				font-family: var(--sans);
			}
			[data-hook="ccsu-cookie-policy-link"] {
				color: var(--accent) !important;
			}
			[data-hook="ccsu-banner-settings"],
			[data-hook="ccsu-banner-decline"] {
				color: var(--fg-muted) !important;
			}
			[data-hook="ccsu-banner-settings"]:hover,
			[data-hook="ccsu-banner-decline"]:hover {
				color: var(--fg) !important;
			}
			[data-hook="ccsu-banner-accept"],
			[data-hook="ccsu-banner-decline-all"] {
				font-family: var(--mono) !important;
				border-radius: 8px !important;
				transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
			}
			[data-hook="ccsu-banner-decline-all"] {
				background: transparent !important;
				border: 1px solid var(--border-strong) !important;
				color: var(--fg-muted) !important;
			}
			[data-hook="ccsu-banner-decline-all"]:hover {
				color: var(--fg) !important;
				border-color: var(--fg-faint) !important;
			}
			[data-hook="ccsu-banner-accept"] {
				background: var(--accent-fade) !important;
				border: 1px solid rgba(250, 255, 0, 0.45) !important;
				color: var(--accent) !important;
			}
			[data-hook="ccsu-banner-accept"]:hover {
				background: var(--accent) !important;
				border-color: var(--accent) !important;
				color: var(--bg) !important;
			}
		</style>
	</head>
	<body>
		<slot />
		<XRayLayer client:load />
	</body>
</html>
