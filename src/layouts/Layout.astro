---
import "../styles/xray.css";
import XRayLayer from "../components/xray/Layer.tsx";

const SITE_URL = "https://www.wix-headless.dev";
const {
	title = "Build a Real Business with AI | Wix Headless",
	description = "Headless commerce, bookings, CMS, identity — agent-wired, prompt-deep. Drop one prompt into any coding agent and ship a business, not a demo.",
	ogTitle = "Build anything. Wix runs the business behind it.",
	ogDescription = "Headless commerce, bookings, CMS, identity — agent-wired, prompt-deep.",
	image = "/og-image.png",
	imageAlt = "Wix Headless — Build anything. Wix runs the business behind it.",
	canonical,
} = Astro.props;
const absoluteImage = image.startsWith("http") ? image : SITE_URL + image;
const ogUrl = canonical ?? SITE_URL + "/";
---
<!doctype html>
<html lang="en">
	<head>
		<slot name="seo-tags" />
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" sizes="192x192" href="/icon.png" />
		<link rel="apple-touch-icon" href="/icon.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="author" content="Wix.com, Inc." />
		{canonical && <link rel="canonical" href={canonical} />}
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={ogTitle} />
		<meta property="og:description" content={ogDescription} />
		<meta property="og:url" content={ogUrl} />
		<meta property="og:image" content={absoluteImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={imageAlt} />
		<meta name="twitter:site" content="@Wix" />
		<meta name="twitter:title" content={ogTitle} />
		<meta name="twitter:description" content={ogDescription} />
		<meta name="twitter:image" content={absoluteImage} />
		<meta name="twitter:image:alt" content={imageAlt} />
		<meta name="theme-color" content="#0a0a0a" />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebSite",
			name: "Wix Headless",
			url: SITE_URL + "/",
			publisher: {
				"@type": "Organization",
				name: "Wix",
				url: "https://www.wix.com/"
			}
		})} />
		<link rel="preconnect" href="https://rsms.me/" />
		<link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
		<!--
			Wix's injected cookie banner (#cookie-banner-root-wix) hard-codes
			`font-family: Madefor-Text, Madefor` with no generic fallback. We don't
			load the Madefor faces, so the banner renders in the browser default and
			looks off vs. the rest of the page. Pin it to Inter to match the site.
		-->
		<style is:global>
			#cookie-banner-root-wix,
			#cookie-banner-root-wix * {
				font-family: "Inter", system-ui, -apple-system, sans-serif !important;
			}
		</style>
	</head>
	<body>
		<slot />
		<XRayLayer client:load />
	</body>
</html>
